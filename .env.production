# Production Environment Variables for Vercel Deployment
# Replace YOUR_BACKEND_URL with your actual backend server URL

# API Configuration - IMPORTANT: Update this with your backend URL
VITE_API_BASE_URL=http://YOUR_BACKEND_URL:5000/api

# TMDB Configuration
VITE_TMDB_API_KEY=your-tmdb-api-key-here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500

# Site Configuration
VITE_SITE_NAME=Nepal Movie
VITE_SITE_URL=http://YOUR_BACKEND_URL:5000

# Example configurations:
# If your backend is on a domain: https://api.yourdomain.com/api
# If your backend is on IP: http://123.456.789.123:5000/api
# If your backend is on localhost (for testing): http://localhost:5000/api