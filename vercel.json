{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "http://172.237.44.29:5000/api",
    "VITE_SITE_NAME": "Nepal Movie"
  },
  "build": {
    "env": {
      "VITE_API_BASE_URL": "http://172.237.44.29:5000/api",
      "VITE_SITE_NAME": "Nepal Movie"
    }
  }
}